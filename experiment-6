<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Event Registration</title>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <style>
    body { font-family: sans-serif; margin: 20px; line-height: 1.6; }
    .form-group { margin-bottom: 15px; }
    label { display: block; font-weight: bold; }
    input { padding: 8px; width: 250px; border: 1px solid #ccc; border-radius: 4px; }
    .error { color: red; font-size: 0.8em; display: block; margin-top: 5px; }
    #success-msg { font-weight: bold; margin-top: 20px; }
    .btn-container { margin-top: 10px; }
    button { padding: 10px 15px; cursor: pointer; }
  </style>
</head>
<body>
  <h2>Event Registration Form</h2>
  <form id="regForm">
    <div class="form-group">
      <label>Participant Name:</label>
      <input type="text" id="name" placeholder="Enter Name">
      <span id="nameError" class="error"></span>
    </div>

    <div class="form-group">
      <label>Email:</label>
      <input type="text" id="email" placeholder="example@mail.com">
      <span id="emailError" class="error"></span>
    </div>

    <div class="form-group">
      <label>Event Name:</label>
      <input type="text" id="event" value="Global Tech Summit 2026" readonly>
    </div>

    <div class="form-group">
      <label>Mobile Number:</label>
      <input type="text" id="mobile" placeholder="Enter Mobile Number">
      <span id="mobileError" class="error"></span>
    </div>

    <div class="btn-container">
      <button type="button" id="submitBtn">Submit</button>
      <button type="button" id="resetBtn">Reset</button>
    </div>
  </form>

  <div id="success-msg"></div>

  <script>
    $(document).ready(function() {

      $("#submitBtn").click(function() {
        // Reset errors and styles first
        $(".error").text("");
        $("input").css("border-color", "#ccc");
        $("#success-msg").text("");

        // Retrieve values using jQuery
        let name = $("#name").val().trim();
        let email = $("#email").val().trim();
        let mobile = $("#mobile").val().trim();
        let isValid = true;

        // Validation: Name
        if (name === "") {
          $("#nameError").text("Name is required").css("color", "red");
          $("#name").css("border-color", "red");
          isValid = false;
        }

        // Validation: Email (Regex for format)
        let emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (email === "") {
          $("#emailError").text("Email is required").css("color", "red");
          $("#email").css("border-color", "red");
          isValid = false;
        } else if (!emailRegex.test(email)) {
          $("#emailError").text("Invalid email format").css("color", "red");
          $("#email").css("border-color", "red");
          isValid = false;
        }

        // Validation: Mobile (Digits only, min 10)
        let mobileRegex = /^\d{10,}$/;
        if (mobile === "") {
          $("#mobileError").text("Mobile number is required").css("color", "red");
          $("#mobile").css("border-color", "red");
          isValid = false;
        } else if (!mobileRegex.test(mobile)) {
          $("#mobileError").text("Must be at least 10 digits").css("color", "red");
          $("#mobile").css("border-color", "red");
          isValid = false;
        }

        // Final check
        if (isValid) {
          $("#success-msg").text("Registration Successful for " + name).css("color", "green");

          // Disable button and change text
          $(this).prop("disabled", true).text("Registered");
        }
      });

      // Reset Button Logic
      $("#resetBtn").click(function() {
        // Clear fields (except the readonly event name)
        $("#name, #email, #mobile").val("");

        // Clear messages and reset borders
        $(".error").text("");
        $("#success-msg").text("");
        $("input").css("border-color", "#ccc");

        // Re-enable submit button
        $("#submitBtn").prop("disabled", false).text("Submit");
      });

    });
  </script>
</body>
</html>
