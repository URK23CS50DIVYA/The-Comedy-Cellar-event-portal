<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Tech Event Registration Portal</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f6f8;
        }

        /* Top Banner */
        header {
            background-color: #b46f14;
            color: white;
            padding: 20px;
            text-align: center;
        }

        header h1 {
            margin: 0;
        }

        /* Main Container */
        .container {
            width: 80%;
            margin: auto;
            background-color: white;
            padding: 20px;
        }

        /* Event Section */
        .event-banner img {
            width: 100%;
            border-radius: 6px;
        }

        .event-details {
            margin-top: 20px;
        }

        .event-details h2 {
            color: #70440a;
        }

        /* Form Section */
        .form-section {
            margin-top: 30px;
        }

        label {
            font-weight: bold;
        }

        input, select, textarea {
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            margin-bottom: 15px;
        }

        input[type="radio"],
        input[type="checkbox"] {
            width: auto;
        }

        button {
            background-color: #9e5f0c;
            color: white;
            border: none;
            padding: 10px;
            font-size: 16px;
            width: 100%;
            cursor: pointer;
        }

        button:hover {
            background-color: #79520a;
        }

        /* Media Section */
        .media-section {
            margin-top: 40px;
        }

        /* Footer */
        footer {
            background-color: #856708;
            color: white;
            text-align: center;
            padding: 10px;
            margin-top: 40px;
        }
    </style>
</head>

<body>

<!-- TOP BANNER -->
<header>
