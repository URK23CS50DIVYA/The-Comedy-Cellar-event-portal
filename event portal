        <img src="C:\Users\urk23cs5012\Downloads\banner-comedy.jpg"alt="Tech Event Banner">
    </div>

    <!-- EVENT DETAILS -->
    <div class="event-details">
        <h2>GET READY TO LAUGH UNTIL IT HURTS!</h2>
